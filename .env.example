# ── Lister-Bridge Hybrid Agent — Environment Template ────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`
# (it is in .gitignore — PI-002). All eBay work is sandbox-first (EBAY_ENV).

# ─────────────────────────────────────────────────────────────────────────────
# Google Drive (existing — drive_fetcher.py)
# ─────────────────────────────────────────────────────────────────────────────

# Google Service Account credentials for Drive API access.
# Point this to the absolute path of your downloaded service account JSON key file.
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json

# Google Drive folder IDs (copy from the URL when the folder is open in Drive).
DRIVE_STAGING_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxx
DRIVE_ARCHIVE_FOLDER_ID=1yyyyyyyyyyyyyyyyyyyyyyyyyyy

# Local image cache directory (relative to project root, or absolute).
# Images are stored here as {file_id}.{ext}. data/ is in .gitignore.
DRIVE_CACHE_DIR=data/cache/images

# ─────────────────────────────────────────────────────────────────────────────
# Gemini (Vision Agent — DECISION D-9)
# ─────────────────────────────────────────────────────────────────────────────

# AI Studio / Gemini API key. Consumer Google One / AI Pro plans do NOT include
# API tokens — API usage is billed separately. Start on the AI Studio free tier.
GEMINI_API_KEY=

# Pinned model. The blueprint commits to Gemini 3.5 Flash (current GA).
GEMINI_MODEL=gemini-3.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# eBay (auth + Media + REST Inventory + Browse)
# ─────────────────────────────────────────────────────────────────────────────

# Environment switch: sandbox | production. Keep on sandbox until the Phase 1
# spike is signed off. ebay_auth.py / ebay_client.py select API hosts from this.
EBAY_ENV=sandbox

# OAuth application credentials (from the eBay developer portal keyset).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# OAuth 2.0 USER refresh token (authorization-code grant). ebay_auth.py exchanges
# this for short-lived (~2h) access tokens and auto-renews them (R-AUTH).
EBAY_OAUTH_REFRESH_TOKEN=

# Space-separated OAuth scopes required by the publish + image + pricing flow.
EBAY_OAUTH_SCOPES=sell.inventory commerce.media buy.browse

# Marketplace the listings are published to.
EBAY_MARKETPLACE_ID=EBAY_US

# Business policy IDs — every createOffer references all three by ID.
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# Merchant inventory location key — required by createOffer / publishOffer.
EBAY_INVENTORY_LOCATION_KEY=

# Default eBay category ID applied to assembled listings (operator can override
# per item in the review UI). Leave blank to force the operator to set it.
EBAY_DEFAULT_CATEGORY_ID=

# ─────────────────────────────────────────────────────────────────────────────
# State store (state_store.py — SQLite)
# ─────────────────────────────────────────────────────────────────────────────

# Path to the SQLite database file (relative to project root, or absolute).
# Holds processed batches, SKUs, offer/listing IDs, and the token cache.
STATE_STORE_DB_PATH=data/state/lister_bridge.db
